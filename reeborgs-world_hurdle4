def turn_right():
    turn_left()
    turn_left()
    turn_left()
    
def hurdle():
    turn_left()
    while front_is_clear()  == True:
        move()
        if right_is_clear() == True:
            turn_right()
            move()
            turn_right()
            move()
    turn_left()
    
while not at_goal() != False:
    if not front_is_clear() == True:
        hurdle()
    else:
        move()
