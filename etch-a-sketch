from turtle import Turtle, Screen
import random

saint = Turtle()
screen = Screen()

def move_forwards():
    saint.forward(10)
def move_backwards():
    saint.backward(10)
def turn_left():
    new_heading = saint.heading() + 10
    saint.setheading(new_heading)
def turn_right():
    new_heading = saint.heading() - 10
    saint.setheading(new_heading)
def clear():
    saint.clear()
    saint.penup()
    saint.goto(0, 0)
    saint.pendown()


screen.listen()
screen.onkey(key="w", fun=move_forwards)
screen.onkey(key="s", fun=move_backwards)
screen.onkey(key="a", fun=turn_left)
screen.onkey(key="d", fun=turn_right)
screen.onkey(key="c", fun=clear)

screen.exitonclick()
