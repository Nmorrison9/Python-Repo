import art
print(art.logo)

bid_price = {}
continue_bidding = True
def find_highest_bidder(bid_price):
    winner = ""
    highest_bid = 0
    for bidder in bid_price:
        bid_amount = bid_price[bidder]
        if bid_amount > highest_bid:
            highest_bid = bid_amount
            winner = bidder
    print(f"The highest bid was ${highest_bid}. Congratulations, {winner.capitalize()}!")

while continue_bidding:
    name = input("What is your name?\n").lower()
    bid = float(input("What is your bid? $"))
    bid_price[name] = bid
    more_bidders = input("Are there any other bidders? Type 'yes' or 'no'.\n").lower()
    print("\n" * 100)

    if more_bidders == "yes":
        continue_bidding = True
    elif more_bidders == "no":
        find_highest_bidder(bid_price)
        continue_bidding = False
    else:
        print("Invalid response, try again")
        input("Are there any other bidders? Type 'yes' or 'no'.\n")
